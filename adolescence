<title>Lesson 4 — Is Adolescence a Western Invention? | Year 11 Society & Culture</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@2.44.0/tabler-icons.min.css">
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:system-ui,-apple-system,sans-serif;background:#f5f5f3;color:#1a1a18;line-height:1.6}
.page{max-width:720px;margin:0 auto;padding:2rem 1.25rem}

/* HERO */
.hero{border-radius:16px;padding:2.5rem 2rem;margin-bottom:1.5rem;background:linear-gradient(135deg,#3C3489 0%,#7F77DD 60%,#B8B4F0 100%);color:#fff;position:relative;overflow:hidden}
.hero::before{content:'';position:absolute;top:-40px;right:-40px;width:180px;height:180px;border-radius:50%;background:rgba(255,255,255,0.07)}
.hero::after{content:'';position:absolute;bottom:-60px;left:30%;width:220px;height:220px;border-radius:50%;background:rgba(255,255,255,0.05)}
.hero-eyebrow{font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.08em;opacity:0.75;margin-bottom:8px}
.hero-title{font-size:26px;font-weight:700;line-height:1.25;margin-bottom:10px}
.hero-sub{font-size:14px;opacity:0.85;line-height:1.6;margin-bottom:1.25rem}
.hero-tags{display:flex;flex-wrap:wrap;gap:8px}
.hero-tag{font-size:12px;padding:4px 12px;border-radius:20px;background:rgba(255,255,255,0.15);color:#fff;border:1px solid rgba(255,255,255,0.25)}

/* RELIEF BANNER */
.relief-banner{background:#FFF8E6;border:1px solid #FAC775;border-radius:12px;padding:1rem 1.25rem;margin-bottom:1.5rem;display:flex;gap:10px;align-items:flex-start}
.relief-banner i{color:#854F0B;font-size:20px;flex-shrink:0;margin-top:2px}
.relief-label{font-size:11px;font-weight:600;color:#854F0B;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:4px}
.relief-text{font-size:13px;color:#633806;line-height:1.6}

/* PROGRESS */
.progress-row{display:flex;gap:6px;margin-bottom:1.5rem;align-items:center}
.prog-label{font-size:12px;color:#6b6b68;white-space:nowrap;margin-right:4px}
.prog-step{flex:1;height:5px;border-radius:3px;background:#e0dfd8;transition:background 0.3s}
.prog-step.done{background:#1D9E75}
.prog-step.active{background:#7F77DD}

/* CARDS */
.section-card{background:#fff;border:1px solid #e0dfd8;border-radius:12px;overflow:hidden;margin-bottom:1.25rem}
.section-header{padding:0.875rem 1.25rem;border-bottom:1px solid #e0dfd8;display:flex;align-items:center;gap:10px}
.section-num{width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:600;flex-shrink:0}
.s1 .section-num{background:#EEEDFE;color:#3C3489}
.s2 .section-num{background:#E1F5EE;color:#085041}
.s3 .section-num{background:#FAECE7;color:#712B13}
.s4 .section-num{background:#E6F1FB;color:#0C447C}
.s5 .section-num{background:#FAEEDA;color:#633806}
.s6 .section-num{background:#F3E8FB;color:#5C1F8A}
.section-title{font-size:14px;font-weight:600;color:#1a1a18;flex:1}
.section-time{font-size:12px;color:#9b9b98;display:flex;align-items:center;gap:4px}
.section-body{padding:1.25rem}
.prose{font-size:14px;color:#444441;line-height:1.75;margin-bottom:1rem}

/* RECALL STRIP */
.recall-strip{background:linear-gradient(135deg,#EEEDFE,#E6F1FB);border-radius:10px;padding:1rem 1.25rem;margin-bottom:1rem;display:flex;gap:12px;align-items:flex-start}
.recall-icon{width:36px;height:36px;border-radius:8px;background:#fff;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.recall-icon i{font-size:18px;color:#534AB7}
.recall-label{font-size:11px;font-weight:600;color:#3C3489;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:3px}
.recall-text{font-size:13px;color:#3C3489;line-height:1.55}

/* KEY IDEA */
.key-idea{background:#f5f5f3;border-left:3px solid #7F77DD;padding:0.875rem 1rem;margin-bottom:1rem}
.key-idea-label{font-size:11px;font-weight:600;color:#534AB7;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:5px}
.key-idea-text{font-size:14px;color:#1a1a18;line-height:1.65}

/* IMAGE CARDS */
.image-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:1rem}
.image-card{border-radius:10px;overflow:hidden;border:1px solid #e0dfd8}
.image-card img{width:100%;height:160px;object-fit:cover;display:block}
.image-card-body{padding:0.75rem}
.image-card-title{font-size:13px;font-weight:600;color:#1a1a18;margin-bottom:3px}
.image-card-desc{font-size:12px;color:#6b6b68;line-height:1.5}
.image-card-tag{display:inline-block;font-size:10px;padding:2px 8px;border-radius:20px;margin-top:5px;font-weight:500}
.tag-challenge{background:#FAECE7;color:#712B13}
.tag-support{background:#E1F5EE;color:#085041}
.tag-complex{background:#EEEDFE;color:#3C3489}

/* QUOTE BLOCK */
.quote-block{background:#1a1a18;border-radius:10px;padding:1.25rem 1.5rem;margin-bottom:1rem;position:relative}
.quote-mark{font-size:48px;color:#7F77DD;line-height:0.8;margin-bottom:8px;display:block;font-family:Georgia,serif}
.quote-text{font-size:15px;color:#fff;line-height:1.65;font-style:italic;margin-bottom:8px}
.quote-source{font-size:12px;color:#9b9b98}

/* CONTROVERSY GRID */
.controversy-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:1rem}
.controversy-card{border-radius:10px;padding:1rem;border:2px solid transparent;cursor:pointer;transition:all 0.15s}
.cv-agree{background:#E1F5EE;border-color:#E1F5EE}
.cv-disagree{background:#FAECE7;border-color:#FAECE7}
.cv-partly{background:#EEEDFE;border-color:#EEEDFE;grid-column:span 2}
.controversy-card.selected.cv-agree{border-color:#1D9E75}
.controversy-card.selected.cv-disagree{border-color:#D85A30}
.controversy-card.selected.cv-partly{border-color:#7F77DD}
.cv-title{font-size:13px;font-weight:600;margin-bottom:4px}
.cv-agree .cv-title{color:#085041}
.cv-disagree .cv-title{color:#712B13}
.cv-partly .cv-title{color:#3C3489}
.cv-desc{font-size:12px;line-height:1.5}
.cv-agree .cv-desc{color:#0F6E56}
.cv-disagree .cv-desc{color:#993C1D}
.cv-partly .cv-desc{color:#534AB7}

/* EVIDENCE STRIPS */
.evidence-list{display:flex;flex-direction:column;gap:8px;margin-bottom:1rem}
.evidence-item{background:#f5f5f3;border-radius:8px;padding:0.75rem 1rem;display:flex;gap:10px;align-items:flex-start}
.evidence-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;margin-top:5px}
.evidence-text{font-size:13px;color:#444441;line-height:1.55}
.evidence-source{font-size:11px;color:#9b9b98;margin-top:3px}

/* VIDEO */
.video-block{background:#f5f5f3;border:1px solid #e0dfd8;border-radius:8px;padding:0.875rem 1rem;margin-bottom:1rem;display:flex;align-items:center;gap:12px;text-decoration:none}
.video-icon{width:36px;height:36px;border-radius:8px;background:#FAECE7;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.video-icon i{font-size:18px;color:#D85A30}
.video-title{font-size:13px;font-weight:600;color:#1a1a18;margin-bottom:2px}
.video-meta{font-size:12px;color:#6b6b68}

/* ACTIVITY */
.activity-box{background:#f5f5f3;border-radius:8px;padding:1rem;margin-bottom:1rem}
.activity-label{font-size:11px;font-weight:600;color:#0F6E56;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:8px;display:flex;align-items:center;gap:5px}
.activity-label i{font-size:14px}
.activity-q{font-size:14px;color:#1a1a18;line-height:1.6;margin-bottom:5px}
.think-prompt{font-size:13px;color:#6b6b68;font-style:italic}

/* PEEL */
.peel-box{background:#fff;border:1px solid #e0dfd8;border-radius:8px;padding:1rem;margin-top:10px}
.peel-row{display:flex;gap:10px;align-items:flex-start;margin-bottom:10px}
.peel-row:last-child{margin-bottom:0}
.peel-letter{width:30px;height:30px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:700;flex-shrink:0}
.peel-name{font-size:13px;font-weight:600;color:#1a1a18;margin-bottom:2px}
.peel-hint{font-size:12px;color:#6b6b68;line-height:1.5}

/* COMPLETE BTN */
.complete-btn{width:100%;padding:11px;border-radius:8px;border:1px solid #e0dfd8;background:#fff;font-size:13px;font-weight:600;color:#6b6b68;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:6px;transition:all 0.15s;margin-top:8px}
.complete-btn:hover{background:#f5f5f3}
.complete-btn.done{background:#E1F5EE;border-color:#5DCAA5;color:#085041}

/* FORM */
.form-box{background:#fff;border:1px solid #e0dfd8;border-radius:10px;padding:1rem 1.25rem;display:flex;align-items:center;gap:12px}
.form-icon{width:38px;height:38px;border-radius:8px;background:#E6F1FB;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.form-icon i{font-size:20px;color:#185FA5}
.form-text{flex:1}
.form-title{font-size:13px;font-weight:600;color:#1a1a18;margin-bottom:2px}
.form-sub{font-size:12px;color:#6b6b68}
.form-btn{font-size:12px;padding:8px 16px;border-radius:8px;background:#E6F1FB;color:#185FA5;border:none;cursor:pointer;font-weight:600;white-space:nowrap;text-decoration:none;display:inline-block}
.form-btn:hover{background:#B5D4F4}

/* STAT CARDS */
.stat-row{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:1rem}
.stat-card{background:#f5f5f3;border-radius:10px;padding:0.875rem;text-align:center}
.stat-num{font-size:24px;font-weight:700;margin-bottom:2px}
.stat-label{font-size:11px;color:#6b6b68;line-height:1.4}

@media(max-width:520px){
  .image-grid{grid-template-columns:1fr}
  .controversy-grid{grid-template-columns:1fr}
  .cv-partly{grid-column:span 1}
  .stat-row{grid-template-columns:1fr}
  .hero-title{font-size:20px}
}
</style>
